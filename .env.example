# Bubblewire keeps provider credentials server-side.

# Twitch EventSub chat.message preferred path.
TWITCH_CLIENT_ID=
TWITCH_BOT_USER_ACCESS_TOKEN=
TWITCH_BOT_USER_ID=
TWITCH_BROADCASTER_USER_ID=

# Twitch anonymous read-only IRC fallback. Set only channels to read public chat
# without account credentials. Add username/token for authenticated IRC.
TWITCH_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNELS=

# X filtered stream. Create rules in X first, then start Bubblewire.
X_BEARER_TOKEN=

# Kick webhook routing. Use a public tunnel for local demos.
KICK_WEBHOOK_PUBLIC_URL=
KICK_AUTO_SUBSCRIBE=0
KICK_ACCESS_TOKEN=
KICK_BROADCASTER_USER_ID=
KICK_REQUIRE_SIGNATURE=0

PORT=3000

# Set to off/live/false/0 to disable all demo events and demo controls.
DEMO_MODE=on

# Message history (NDJSON log powering "Load older"). Set off to disable.
HISTORY=on
# HISTORY_FILE=data/feed.ndjson

# Optional: require x-admin-token header for runtime Twitch channel changes.
ADMIN_TOKEN=
