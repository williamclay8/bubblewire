# Bubblewire keeps provider credentials server-side.

# Twitch EventSub chat.message preferred path.
TWITCH_CLIENT_ID=
TWITCH_BOT_USER_ACCESS_TOKEN=
TWITCH_BOT_USER_ID=
TWITCH_BROADCASTER_USER_ID=

# Twitch anonymous read-only IRC fallback. Set only channels to read public chat
# without account credentials. Add username/token for authenticated IRC.
TWITCH_USERNAME=
TWITCH_OAUTH_TOKEN=
TWITCH_CHANNELS=

# X filtered stream. Local/dev is disabled by default so it cannot consume the
# single live stream connection. Render production streams and clears stale
# TooManyConnections sessions by default; set either flag to off to opt out.
X_BEARER_TOKEN=
X_STREAM_ENABLED=off
X_STREAM_PAUSED=0
X_AUTO_TERMINATE_CONNECTIONS=
X_AUTO_TERMINATE_RECONNECT_MS=2000
X_TOO_MANY_CONNECTIONS_BACKOFF_MS=300000
X_RATE_LIMIT_BACKOFF_MS=300000
X_USAGE_CAP_BACKOFF_MS=1800000

# X Live (source `xlive`): comments on a live X video broadcast. They are
# replies to the broadcast post and ride the SAME single filtered-stream
# connection via a conversation_id rule. Set the broadcast post URL or numeric
# id at boot here, or at runtime with POST /api/xlive/broadcast { "url": ... }.
X_LIVE_BROADCAST_ID=
# XLIVE_FILE=data/xlive.json

# Kick webhook routing. Use a public tunnel for local demos.
KICK_WEBHOOK_PUBLIC_URL=
KICK_AUTO_SUBSCRIBE=0
KICK_ACCESS_TOKEN=
KICK_BROADCASTER_USER_ID=
KICK_REQUIRE_SIGNATURE=0

PORT=3000

# Set to off/live/false/0 to disable all demo events and demo controls.
DEMO_MODE=on

# Message history (NDJSON log powering "Load older"). Set off to disable.
HISTORY=on
# HISTORY_FILE=data/feed.ndjson

# Optional: require x-admin-token header for runtime Twitch channel changes.
ADMIN_TOKEN=
